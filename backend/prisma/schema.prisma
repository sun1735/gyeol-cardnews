generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 사용자 — 이메일 + 비밀번호(해시) 또는 소셜 로그인(Google/Kakao/Naver). 브랜드 소유·접근 제어 + 플랜 주체.
model User {
  id             String         @id @default(cuid())
  email          String         @unique
  name           String         @default("")
  imageUrl       String         @default("")
  // 비밀번호 해시 (bcrypt). 소셜 로그인 유저는 null.
  passwordHash   String?
  // 권한: user | admin
  role           String         @default("user")
  // 플랜: free | pro | team
  plan           String         @default("free")
  planStartedAt  DateTime?
  planExpiresAt  DateTime?      // 정기결제 만료/취소 시점 — 지나면 free 로 복귀
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  brands         BrandProfile[]
  usageCounters  UsageCounter[]

  @@map("users")
}

// 월간 사용량 카운터 — 플랜 한도 체크 및 과금 기반.
// (userId, yearMonth) 쌍으로 한 달에 한 행.
model UsageCounter {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  yearMonth     String   // "2026-04" (UTC 기준)
  imageGenCount Int      @default(0)  // AI 이미지 생성 + 편집 (둘 다 고비용)
  textGenCount  Int      @default(0)  // 텍스트 카드 생성 (저비용)
  ragJobCount   Int      @default(0)  // RAG 비동기 잡 (텍스트+이미지 묶음)
  ideaGenCount  Int      @default(0)  // 아이디어 추천
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, yearMonth])
  @@index([userId, yearMonth])
  @@map("usage_counters")
}

model BrandProfile {
  id             String                @id @default(cuid())
  // ownerId 없으면(null) 레거시·시드 브랜드 — 모든 로그인 유저가 읽기만 가능, 수정·삭제 불가
  ownerId        String?
  owner          User?                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name           String                @unique
  tone           String                @default("")
  defaultPhrase  String                @default("")
  primaryColor   String                @default("#0f766e")
  secondaryColor String                @default("#f0fdfa")
  textColor      String                @default("#111827")
  fontFamily     String                @default("Pretendard, sans-serif")
  assets         BrandAsset[]
  projects       Project[]
  knowledgeDocs  BrandKnowledgeDoc[]
  knowledgeChunks BrandKnowledgeChunk[]
  imageAssets    BrandImageAsset[]
  ideas          BrandIdea[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([ownerId])
  @@map("brand_profiles")
}

// Gemini 가 제안한 카드뉴스 아이디어 — 브랜드별로 누적 저장, 사용자가 선별·삭제.
model BrandIdea {
  id             String   @id @default(cuid())
  brandId        String
  title          String
  prompt         String
  suggestedCount Int      @default(5)
  reason         String   @default("")
  usesImages     String   @default("") // JSON array
  createdAt      DateTime @default(now())

  brand BrandProfile @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId, createdAt])
  @@map("brand_ideas")
}

// 브랜드 자료 문서. 카피라이팅용 컨텍스트 — 제품 설명·보도자료·FAQ 등을 수집.
model BrandKnowledgeDoc {
  id          String   @id @default(cuid())
  brandId     String
  title       String
  sourceType  String   // upload | url | note
  sourceUrl   String?
  contentText String   @default("")
  status      String   @default("ready") // ready | indexing | failed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand  BrandProfile          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  chunks BrandKnowledgeChunk[]

  @@index([brandId, createdAt])
  @@map("brand_knowledge_docs")
}

// 청크 단위 검색 유닛. MVP 는 키워드(BM25-like) 매칭 — embedding 컬럼은 후속용 자리.
model BrandKnowledgeChunk {
  id         String   @id @default(cuid())
  brandId    String
  docId      String
  chunkIndex Int
  text       String
  tokenCount Int      @default(0)
  embedding  String?  // JSON stringified vector, 추후 pgvector 컬럼으로 교체 권장
  createdAt  DateTime @default(now())

  brand BrandProfile      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  doc   BrandKnowledgeDoc @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@index([brandId, docId])
  @@map("brand_knowledge_chunks")
}

// 태그 달린 이미지 라이브러리. 카드별 이미지 후보 랭킹 대상.
// DB 에는 파일 바이너리 대신 "관리 정보"만 저장 — 실제 파일은 스토리지(현재 로컬/Volume, 차후 R2).
model BrandImageAsset {
  id           String   @id @default(cuid())
  brandId      String
  url          String    // 원본 (WebP 변환본) URL
  thumbnailUrl String?   // 512px 썸네일 URL — 그리드·미리보기용
  label        String   @default("")
  tags         String   @default("") // JSON stringified string[] — 간단 매칭용
  usageRights  String   @default("owned") // owned | licensed | unknown
  qualityScore Float    @default(0.5) // 0~1
  // 메타데이터 (Stage 1 — sharp 로 자동 추출)
  width        Int?
  height       Int?
  sizeBytes    Int?
  mimeType     String?
  sha256       String?   // 전역 중복 제거 키
  createdAt    DateTime @default(now())

  brand BrandProfile @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId, createdAt])
  @@index([sha256])
  @@map("brand_image_assets")
}

// 비동기 카드 생성 잡. Postgres row 가 source of truth.
// 부팅 시 status='running' 행은 'failed' 로 복구해서 좀비 방지.
model GenerationJob {
  id           String   @id @default(cuid())
  brandId      String?
  mode         String   // note_rag (현재) | future modes
  status       String   @default("queued") // queued | running | partial | done | failed
  requestJson  String   // 원 요청 payload
  resultJson   String?  // 결과 cards + meta
  errorMessage String?
  progress     Int      @default(0) // 0~100
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, createdAt])
  @@map("generation_jobs")
}

model BrandAsset {
  id        String       @id @default(cuid())
  brandId   String
  brand     BrandProfile @relation(fields: [brandId], references: [id], onDelete: Cascade)
  url       String
  caption   String       @default("")
  kind      String       @default("image") // image | font
  createdAt DateTime     @default(now())

  @@index([brandId])
  @@map("brand_assets")
}

model Project {
  id         String        @id @default(cuid())
  brandId    String?
  brand      BrandProfile? @relation(fields: [brandId], references: [id], onDelete: SetNull)
  title      String        @default("")
  prompt     String        @default("")
  sizePreset String        @default("1:1")  // 1:1 | 4:5 | 9:16
  inputMode  String        @default("auto") // auto | manual
  cards      Card[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([brandId])
  @@map("projects")
}

// 생성 요청 감사 로그. 민감정보 최소화 — 원문 대신 해시·미리보기 80자·카테고리·메트릭만.
// 운영상 이상 패턴(높은 실패율, 비정상 길이 등) 분석과 법적 기록 유지에 사용.
model GenerationLog {
  id            String   @id @default(cuid())
  timestamp     DateTime @default(now())
  mode          String   // auto | manual
  brandId       String?
  promptHash    String?  // sha-256 앞 16자 — 원문 저장은 피함
  promptPreview String?  // 앞 80자 (디버깅 편의)
  count         Int      @default(0)
  outcome       String   // success | partial | failed | blocked
  source        String?  // llm | template | mixed
  retries       Int      @default(0)
  durationMs    Int      @default(0)
  timedOut      Boolean  @default(false)
  blockedBy     String?  // safety 카테고리 (차단 시)
  clientIp      String?

  @@index([timestamp])
  @@index([outcome])
  @@map("generation_logs")
}

model Card {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  title     String   @default("")
  body      String   @default("")
  subtext   String   @default("") // 단계 4: 보조 텍스트
  cta       String   @default("") // 단계 4: Call-to-Action
  imageUrl  String?
  layout    String   @default("content") // cover | content | cta
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, order])
  @@map("cards")
}
